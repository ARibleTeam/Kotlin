<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/playlist_cover"
        android:layout_width="match_parent"
        android:layout_height="@dimen/playlist_grid_image_size"
        android:background="@drawable/playlist_cover_placeholder_bg"
        android:contentDescription="@string/playlist_cover_content_description"
        android:scaleType="centerCrop"
        tools:src="@drawable/placeholder" />

    <TextView
        android:id="@+id/playlist_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:textColor="@color/yp_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="The Beatles collection" />

    <TextView
        android:id="@+id/playlist_track_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/yp_gray"
        android:textSize="13sp"
        tools:text="12 треков" />

</LinearLayout>
